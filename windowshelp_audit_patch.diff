+fn child_prefix_like(prefix: &str) -> String {
+    let escaped = prefix
+        .replace('\\', "\\\\")
+        .replace('%', "\\%")
+        .replace('_', "\\_");
+    if prefix.ends_with('\\') {
+        format!("{escaped}%")
+    } else {
+        format!("{escaped}\\\\%")
+    }
